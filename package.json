{
  "name": "renaiss-atlas",
  "version": "0.1.0",
  "private": true,
  "description": "Renaiss Atlas turns collector-market signals into source-aware next actions.",
  "type": "module",
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @renaiss/web test:e2e",
    "security:scan": "node scripts/security-scan.mjs",
    "verify:vercel-env": "ATLAS_VERIFY_ENV=true node scripts/verify-vercel-env.mjs",
    "screenshots": "CAPTURE_SCREENSHOTS=true playwright test --config playwright.config.ts apps/web/tests/screenshots.spec.ts",
    "discord:register": "tsx scripts/register-discord-commands.ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
