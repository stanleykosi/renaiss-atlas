# Core
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1
LOG_LEVEL=info

# Official Renaiss OS Index API
# Keep API key and secret server-side only. They must never be prefixed with NEXT_PUBLIC_.
RENAISS_OS_BASE_URL=https://api.renaissos.com
RENAISS_OS_API_KEY=
RENAISS_OS_API_SECRET=

# Redis REST cache and rate-limit state (Upstash-compatible)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI memo layer
AI_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Discord interactions webhook
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Production observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=local
