# Core
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1
API_PORT=3001
DATABASE_URL=
DATABASE_SSL=false
JOB_SECRET=replace-with-strong-random-value
LOG_LEVEL=info
JOB_LOCK_TTL_SECONDS=900

# Redis REST rate limiting (Upstash-compatible)
INTENT_RATE_LIMIT_REDIS_REST_URL=
INTENT_RATE_LIMIT_REDIS_REST_TOKEN=
# Optional fallback names used by Upstash/Vercel integrations
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Renaiss connectors
RENAISS_MARKETPLACE_STRATEGY=auto
RENAISS_V0_MARKETPLACE_URL=https://api.renaiss.xyz/v0/marketplace
RENAISS_TRPC_MARKETPLACE_URL=https://www.renaiss.xyz/api/trpc/collectible.list
RENAISS_SYNC_LIMIT=5000
RENAISS_SYNC_PAGE_SIZE=50
RENAISS_SYNC_MAX_PAGES=100
RENAISS_SYNC_LISTED_ONLY=true
RENAISS_SYNC_RATE_LIMIT_MS=750
RENAISS_SYNC_RETRY_ATTEMPTS=3

# Gacha connector
GACHA_SYNC_ENABLED=true
GACHA_SYNC_INTERVAL_SECONDS=60
GACHA_PACKS=renacrypt-pack,omega
GACHA_RSC_BASE_URL=https://www.renaiss.xyz/gacha
GACHA_SYNC_RATE_LIMIT_MS=750
GACHA_SYNC_RETRY_ATTEMPTS=3

# External comps
EXTERNAL_COMPS_ENABLED=true
EXTERNAL_COMPS_LIVE_ENABLED=false
EXTERNAL_COMP_SOURCES=snkrdunk,pricecharting
EXTERNAL_COMP_BATCH_SIZE=25
EXTERNAL_COMP_STALE_DAYS=7
EXTERNAL_COMP_RATE_LIMIT_MS=750
EXTERNAL_COMP_RETRY_ATTEMPTS=3
JINA_READER_BASE_URL=https://r.jina.ai/
SNKRDUNK_SEARCH_URL=https://snkrdunk.com/en/search/result
PRICECHARTING_SEARCH_URL=https://www.pricecharting.com/search-products
PRICECHARTING_API_URL=https://www.pricecharting.com/api/products
PRICECHARTING_API_TOKEN=
EXCHANGE_RATES_LIVE_ENABLED=false
EXCHANGE_RATES_URL=https://open.er-api.com/v6/latest/USD
HTTPS_PROXY=

# AI
AI_ENABLED=false
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5

# Discord
DISCORD_ENABLED=false
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_TEST_GUILD_ID=
DISCORD_WEBHOOK_URL=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=local
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# Demo/feature flags
DEMO_MODE=true
MOCK_EXTERNAL_COMPS=true
ALLOW_INTENT_CREATION=true
ENABLE_COLLATERAL_READINESS=true
ENABLE_PACK_MOMENTUM=true
WORKER_CONCURRENCY=2
